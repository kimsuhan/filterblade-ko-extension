{
  "manifest_version": 3,
  "name": "FilterBlade 한국어 번역",
  "description": "FilterBlade PoE2 페이지의 주요 UI 문구를 한국어로 번역합니다.",
  "version": "0.2.17",
  "action": {
    "default_title": "FilterBlade 한국어 번역",
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.filterblade.xyz/*",
        "https://filterblade.xyz/*"
      ],
      "js": [
        "poe2-item-names.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
